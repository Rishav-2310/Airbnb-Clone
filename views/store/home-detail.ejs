<%- include('../partials/head') %>
</head>
<body class="bg-gray-50 text-gray-800">
  <%- include('../partials/nav') %>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <a href="/" class="inline-flex items-center text-sm text-gray-600 hover:underline mb-6">&larr; Back to listings</a>

    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Image / gallery -->
        <div class="h-80 lg:h-auto bg-gray-200 flex items-center justify-center overflow-hidden">
          <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover">
        </div>

        <!-- Details -->
        <div class="p-6 flex flex-col">
          <div>
            <h1 class="text-2xl font-bold text-gray-900"><%= home.houseName %></h1>
            <p class="mt-1 text-sm text-gray-500"><i class="fas fa-map-marker-alt mr-1"></i> <%= home.location %></p>

            <div class="mt-4 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="flex items-center text-yellow-400">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 mr-1">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-gray-700 font-medium"><%= home.rating || '—' %></span>
                </div>
                <span class="text-sm text-gray-500">•</span>
                <span class="text-sm text-gray-600">Rs <span class="font-semibold"><%= home.price %></span> / night</span>
              </div>

              <div class="flex items-center gap-3">
                <%- include('../partials/favourite', {home: home}) %>
              </div>
            </div>

            <hr class="my-4">

            <h2 class="text-lg font-semibold text-gray-900">About this home</h2>
            <p class="mt-2 text-sm text-gray-700 leading-relaxed"><%= home.description || 'No description provided for this home.' %></p>

            <% if (home.rules) { %>
                <div class="mt-4">
                    <a href="/rules/<%= home._id %>" class="inline-flex items-center text-blue-600 hover:text-blue-800">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l.414.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        Download House Rules
                    </a>
                </div>
            <% } %>
          </div>

          <div class="mt-6 border-t pt-4">
            <div class="flex items-center gap-3">
              <a href="/reserve/<%= home._id %>" class="inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-md">Reserve</a>
              <a href="/homes/<%= home._id %>/book" class="inline-flex items-center px-4 py-2 border border-gray-200 rounded-md text-sm text-gray-700 hover:bg-gray-50">Check availability</a>

              <% /* optional host contact or other actions could go here */ %>
            </div>

            <p class="mt-3 text-xs text-gray-500">For bookings, follow the reserve flow. Hosts typically respond within 24 hours.</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>