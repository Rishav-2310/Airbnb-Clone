<%- include('../partials/head') %>

</head>
<body class="bg-gray-50 text-gray-800">
    <%- include('../partials/nav') %>

    <main class="flex justify-center py-12 px-4">
        <div class="w-full max-w-4xl bg-white rounded-xl shadow-md overflow-hidden">
            <div class="px-6 py-5 bg-linear-to-r from-red-600 to-red-500">
                <h2 class="text-white text-2xl md:text-3xl font-semibold"><%= editing ? 'Edit your home' : 'Register your home' %></h2>
                <p class="text-red-100 mt-1 text-sm"><%= editing ? 'Make changes to your listing and save.' : 'Fill out the form to add your property.' %></p>
            </div>

            <div class="p-6">
                <form action="/host/<%= editing ? 'edit-home' : 'add-home' %>" method="POST" enctype="multipart/form-data" class="space-y-6">
                    <input type="hidden" name="id" value="<%= editing ? home._id : '' %>">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700">House name <span class="text-red-500">*</span></label>
                            <input name="houseName" type="text" value="<%= editing ? home.houseName : '' %>" placeholder="Cozy Downtown Apartment" class="mt-1 block w-full rounded-md border-gray-200 p-3 shadow-sm focus:ring-red-400 focus:border-red-400" required>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700">Price (₹ / night) <span class="text-red-500">*</span></label>
                            <input name="price" type="number" value="<%= editing ? home.price : '' %>" placeholder="2500" class="mt-1 block w-full rounded-md border-gray-200 p-3 shadow-sm focus:ring-red-400 focus:border-red-400" min="0" required>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700">Location <span class="text-red-500">*</span></label>
                            <input name="location" type="text" value="<%= editing ? home.location : '' %>" placeholder="City, area or address" class="mt-1 block w-full rounded-md border-gray-200 p-3 shadow-sm focus:ring-red-400 focus:border-red-400" required>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700">Rating</label>
                            <input name="rating" type="number" value="<%= editing ? home.rating : '' %>" placeholder="0 - 5" class="mt-1 block w-full rounded-md border-gray-200 p-3 shadow-sm focus:ring-red-400 focus:border-red-400" step="0.1" min="0" max="5">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700">Photo</label>
                            <input name="photo" type="file" accept="image/*" class="mt-1 block w-full rounded-md border-gray-200 p-2">
                            <p class="text-xs text-gray-500 mt-1">JPG, PNG recommended. Max 5MB.</p>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700">Rules (PDF only)</label>
                            <input name="rules" type="file" accept="application/pdf" class="mt-1 block w-full rounded-md border-gray-200 p-2">
                            <p class="text-xs text-gray-500 mt-1">Upload house rules as a PDF (optional).</p>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700">Description</label>
                        <textarea name="description" rows="4" placeholder="Describe your home, highlights, amenities, etc." class="mt-1 block w-full rounded-md border-gray-200 p-3 shadow-sm focus:ring-red-400 focus:border-red-400"><%= editing ? home.description : '' %></textarea>
                    </div>

                    <div class="flex items-center justify-between gap-3">
                        <div class="flex items-center gap-3">
                            <button type="submit" class="inline-flex items-center px-4 py-2 bg-red-500 text-white rounded-md hover:bg-red-400 focus:outline-none focus:ring-2 focus:ring-red-200">
                                <%= editing ? 'Update Listing' : 'Add Home' %>
                            </button>
                            <a href="/host/host-home-list" class="text-sm text-gray-600 hover:underline">Cancel</a>
                        </div>

                        <% if (editing && home && home.rulesUrl) { %>
                            <a href="<%= home.rulesUrl %>" target="_blank" class="text-sm text-red-500 hover:underline">View current rules (PDF)</a>
                        <% } %>
                    </div>
                </form>
            </div>
        </div>
    </main>

</body>
</html>