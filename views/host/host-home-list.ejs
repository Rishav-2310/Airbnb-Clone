<%- include('../partials/head') %>
</head>
<body class="bg-gray-50 text-gray-800">
    <%- include('../partials/nav') %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight">Your listings</h1>
                <p class="mt-1 text-sm text-gray-600">Manage the homes you've added. Edit details, upload rules or remove a listing.</p>
            </div>
            <div class="flex items-center gap-3">
                <a href="/host/add-home" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">Add new home</a>
            </div>
        </div>

        <% if (!registeredHomes || registeredHomes.length === 0) { %>
            <div class="bg-white border border-dashed border-gray-200 rounded-lg p-8 text-center">
                <h2 class="text-xl font-semibold">No homes yet</h2>
                <p class="mt-2 text-sm text-gray-500">You don't have any homes listed. Click "Add new home" to create your first listing.</p>
            </div>
        <% } else { %>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                <% registeredHomes.forEach(home => { %>
                    <article class="bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition">
                        <div class="h-48 bg-gray-200 overflow-hidden">
                            <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover">
                        </div>
                        <div class="p-4">
                            <div class="flex items-start justify-between">
                                <div>
                                    <h3 class="text-lg font-semibold text-gray-900"><%= home.houseName %></h3>
                                    <p class="text-sm text-gray-500 mt-1"><i class="fas fa-map-marker-alt mr-1"></i> <%= home.location %></p>
                                </div>
                                <div class="text-right">
                                    <div class="flex items-center justify-end text-sm text-yellow-400">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 mr-1">
                                            <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                                        </svg>
                                        <span class="text-gray-700"><%= home.rating || '—' %></span>
                                    </div>
                                    <div class="text-sm text-red-600 font-semibold mt-2">Rs <%= home.price %> <span class="text-gray-400 font-normal">/ night</span></div>
                                </div>
                            </div>

                            <p class="mt-3 text-sm text-gray-600 line-clamp-3"><%= home.description ? home.description.substring(0, 140) : 'No description provided.' %></p>

                            <div class="mt-4 flex items-center gap-2">
                                <a href="/host/edit-home/<%=home._id%>?editing=true" class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700">Edit</a>

                                <form action="/host/delete-home/<%= home._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this home?');">
                                    <button type="submit" class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700">Delete</button>
                                </form>

                                <% if (home.rulesUrl) { %>
                                    <a href="<%= home.rulesUrl %>" target="_blank" class="ml-auto text-sm text-indigo-600 hover:underline">View rules</a>
                                <% } %>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </main>
</body>
</html>